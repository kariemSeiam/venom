## Scenario 5: Multi-file Feature Complete

**Owner:** "make the middleware reusable"

**Builder:**

```typescript
// src/middleware/factory.ts
export const createAuthMiddleware = (options: AuthOptions) => {
  return async (req: Request, res: Response, next: NextFunction) => {
    const token = req.headers.authorization?.replace('Bearer ', '') ?? req.cookies?.accessToken;
    if (!token && !options.optional) return res.status(401).json({ error: 'Unauthorized' });
    if (!token) return next();
    try {
      (req as AuthRequest).user = await verifyToken(token);
      next();
    } catch {
      return res.status(401).json({ error: 'Invalid token' });
    }
  };
};

// Usage:
export const requireAuth = createAuthMiddleware({ optional: false });
export const optionalAuth = createAuthMiddleware({ optional: true });
```
✓

Ship or don't.

